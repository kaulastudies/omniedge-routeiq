APP_NAME="OmniEdge RouteIQ API"
APP_VERSION="0.1.0"
ENVIRONMENT="local"
CORS_ORIGINS='["http://localhost:3000", "https://omniedge-routeiq.vercel.app"]'

# Local inference
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_TIMEOUT_SECONDS=18

# Cloud inference. Leave empty for mock fallback demos.
FIREWORKS_API_KEY=""
FIREWORKS_BASE_URL="https://api.fireworks.ai/inference/v1"
FIREWORKS_MODEL="accounts/fireworks/models/llama-v3p1-70b-instruct"
FIREWORKS_TIMEOUT_SECONDS=28

# Routing economics
CLOUD_COST_PER_1K_TOKENS_USD=0.0009
LOCAL_LATENCY_TARGET_MS=2500
CLOUD_LATENCY_TARGET_MS=5500

# Audit
PERSIST_AUDIT_LOG=true
AUDIT_LOG_PATH="./data/audit/events.jsonl"
