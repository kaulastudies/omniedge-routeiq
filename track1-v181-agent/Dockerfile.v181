# syntax=docker/dockerfile:1.7

FROM ghcr.io/ggml-org/llama.cpp:light

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    ROUTEIQ_LOCAL_ONLY=1 \
    ROUTEIQ_TOTAL_BUDGET_SECONDS=575 \
    QWEN_ENABLED=1 \
    QWEN_BINARY=/app/llama-completion \
    QWEN_MODEL_PATH=/app/models/Qwen3-4B-Q4_K_M.gguf \
    QWEN_THREADS=2 \
    QWEN_CONTEXT_SIZE=4096 \
    QWEN_PROPOSAL_MODE=nonthinking \
    QWEN_PROPOSAL_MAX_TOKENS=1600 \
    QWEN_PROPOSAL_TIMEOUT_SECONDS=220 \
    QWEN_AUDIT_ENABLED=1 \
    QWEN_AUDIT_MODE=thinking \
    QWEN_AUDIT_MAX_TOKENS=1400 \
    QWEN_AUDIT_TIMEOUT_SECONDS=300 \
    QWEN_REASONING_BUDGET=640 \
    QWEN_PRESENCE_PENALTY=0.0

WORKDIR /app

RUN mkdir -p /app/models && python3 - <<'PYMODEL'
import urllib.request
from pathlib import Path
url = "https://huggingface.co/Qwen/Qwen3-4B-GGUF/resolve/main/Qwen3-4B-Q4_K_M.gguf?download=true"
dst = Path("/app/models/Qwen3-4B-Q4_K_M.gguf")
req = urllib.request.Request(url, headers={"User-Agent": "RouteIQ-v1.8-zero"})
with urllib.request.urlopen(req, timeout=180) as src, dst.open("wb") as out:
    while True:
        chunk = src.read(8 * 1024 * 1024)
        if not chunk:
            break
        out.write(chunk)
if dst.stat().st_size < 2_000_000_000:
    raise RuntimeError("Qwen model download incomplete")
print(f"Model ready: {dst.stat().st_size} bytes", flush=True)
PYMODEL

COPY agent.py /app/agent.py
COPY local /app/local

ENTRYPOINT ["python3", "/app/agent.py"]

ENV ROUTEIQ_LOCAL_ONLY=1 \
    ROUTEIQ_TOTAL_BUDGET_SECONDS=575 \
    QWEN_PROPOSAL_MODE=thinking \
    QWEN_PROPOSAL_MAX_TOKENS=1800 \
    QWEN_PROPOSAL_TIMEOUT_SECONDS=430 \
    QWEN_AUDIT_ENABLED=0 \
    QWEN_REASONING_BUDGET=768 \
    QWEN_PRESENCE_PENALTY=0.0
